{
	"name": "monorepo",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"dev": "concurrently --kill-others --raw \"npm run dev --prefix web\"",
		"build": "npm run build --prefix web",
		"start": "concurrently --kill-others --raw",
		"lint": "concurrently --raw \"npm run lint --prefix web\"",
		"predeploy": "npm run build && node -e \"require('fs').writeFileSync('web/dist/.nojekyll', '')\"",
		"deploy": "gh-pages -d web/dist"
	},
	"devDependencies": {
		"concurrently": "^9.1.2",
		"gh-pages": "^6.3.0"
	},
	"workspaces": [
		"web"
	]
}
